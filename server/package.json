{
  "name": "server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch index.js",
    "build": "prisma generate",
    "build:render-api": "npm ci --prefix .. && cd .. && node ./node_modules/prisma/build/index.js migrate deploy --schema ./server/prisma/schema.prisma && node ./node_modules/prisma/build/index.js generate --schema ./server/prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy",
    "start": "node index.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.3"
  }
}
